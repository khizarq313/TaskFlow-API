# TaskFlow API - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=8080

# Database Configuration (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/taskflow
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_db_password_here

# Hibernate DDL Mode (create, update, validate, none)
# Use 'update' for development, 'validate' for production
DDL_AUTO=update

# Database Connection Pool
DB_POOL_SIZE=10
DB_MIN_IDLE=5

# Firebase Authentication
# Method 1 (Recommended for production): Base64-encoded service account JSON
# To encode: cat firebase-service-account.json | base64 -w 0
FIREBASE_SERVICE_ACCOUNT_JSON=

# Method 2: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=

# Method 3: Raw JSON string (escape quotes properly)
FIREBASE_SERVICE_ACCOUNT_JSON_RAW=

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/taskflow-api.log

# Spring Profile (dev, prod)
SPRING_PROFILES_ACTIVE=dev
