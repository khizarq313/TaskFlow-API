# =========================
# 🚀 TaskFlow API - Environment Variables
# =========================

# =========================
# 🗄 Database (PostgreSQL - Neon)
# =========================
DATABASE_URL=jdbc:postgresql://your-hostname/your-database?sslmode=require
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password

# =========================
# 🔥 Firebase Admin SDK (Backend)
# =========================
# Base64 encoded service account JSON
FIREBASE_SERVICE_ACCOUNT_JSON=your_base64_encoded_firebase_json

# =========================
# 🌐 Application Config
# =========================
SPRING_PROFILES_ACTIVE=dev

# =========================
# 🔐 CORS (Frontend URL)
# =========================
CORS_ALLOWED_ORIGINS=http://localhost:5173

# =========================
# ⚙️ JPA / Hibernate
# =========================
# Use 'update' for local development, 'validate' for production
DDL_AUTO=update

# =========================
# 📡 Server Config
# =========================
SERVER_PORT=8080

# =========================
# 🧪 Optional Debug
# =========================
# Set to true only for development
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_HIBERNATE_DDL_AUTO=none